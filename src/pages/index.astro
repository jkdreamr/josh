---
const year = new Date().getFullYear();

type Item = {
	role?: string;
	name: string;
	meta?: string;
	href?: string;
};

type Section = {
	id: string;
	label: string;
	items: Item[];
};

const sections: Section[] = [
	{
		id: 'school',
		label: 'school',
		items: [
			{ role: 'undergrad', name: 'Stanford University', meta: 'CS + Math' },
			{ role: 'student athlete', name: 'Stanford Varsity Rowing', meta: 'coxswain' },
			{ role: 'organizer', name: 'TreeHacks', meta: 'Stanford Hackathon' },
			{ role: 'head of growth', name: 'Stanford Blockchain' },
			{ role: 'organizer', name: 'Stanford Math Tournament' },
			{ role: 'frosh battalion', name: 'BASES' },
			{ role: 'financial officer', name: 'AASA' },
			{ role: 'public outreach', name: 'TEDxStanford' },
			{ role: 'intern', name: 'Stanford Concert Network' },
			{ role: 'member', name: 'Stanford Badminton' },
			{ role: 'member', name: 'Kappa Sigma' },
		],
	},
	{
		id: 'work',
		label: 'work',
		items: [
			{ role: 'investment intern', name: 'CRV', meta: 'Jun 2026 — present', href: 'https://www.crv.com/' },
			{ role: 'ecosystem manager', name: 'NEAR Protocol', meta: 'Jun 2025 — Sep 2025', href: 'https://near.ai/' },
			{ role: 'research', name: 'Pantera Capital', meta: 'Feb 2025 — May 2025', href: 'https://panteracapital.com/' },
			{ role: 'intern', name: 'Branch and Bound (CodeTree)', meta: 'Jul 2022 — Sep 2023', href: 'https://www.codetree.ai/' },
		],
	},
	{
		id: 'side-projects',
		label: 'side projects',
		items: [
			{ role: 'founder & ceo', name: 'Alphag3n', meta: 'Sep 2022 — Sep 2024', href: 'https://www.alphag3n.com/' },
			{ role: 'producer', name: '@atkelix', meta: 'making music', href: 'https://www.instagram.com/atkelix/' },
			{ name: 'kookwleigh', meta: 'intimate dinners, by invitation', href: 'https://kookwleigh.vercel.app/' },
			{ name: 'NOVUM', meta: 'artist-led creative technology', href: 'https://novumworld.vercel.app/' },
