---
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="welcome to josh. i like to build and make things i actually use." />
		<meta property="og:title" content="josh" />
		<meta property="og:description" content="welcome to josh. i like to build and make things i actually use." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://joshuakoo.xyz" />
		<title>josh</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;1,300&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet">
	</head>
	<body>
		<main class="page">
			<div class="stack">
				<header class="brand">
					<span class="brand-mark">/josh/</span>
				</header>

				<p class="tagline">
					welcome to josh. i like to build and make things i actually use.
				</p>

				<nav class="links" aria-label="links">
					<a href="mailto:joskoo@stanford.edu">email</a>
					<span aria-hidden="true">·</span>
					<a href="https://x.com/joshuaykoo" target="_blank" rel="noopener noreferrer">x</a>
					<span aria-hidden="true">·</span>
					<a href="https://linkedin.com/in/joshuaykoo" target="_blank" rel="noopener noreferrer">linkedin</a>
					<span aria-hidden="true">·</span>
					<a href="https://github.com/jkdreamr" target="_blank" rel="noopener noreferrer">github</a>
				</nav>
			</div>

			<footer class="footer">
				<span>&copy; {year} joshua koo</span>
			</footer>
		</main>
	</body>
</html>

<style is:global>
	:root {
		--bg: #ffffff;
		--ink: #111111;
		--muted: #8a8a8a;
		--rule: #ececec;
		--accent: #111111;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: #0e0e0e;
			--ink: #f3f3f3;
			--muted: #7a7a7a;
			--rule: #1d1d1d;
			--accent: #f3f3f3;
		}
	}

	* {
		box-sizing: border-box;
	}

	html, body {
		margin: 0;
		padding: 0;
		height: 100%;
	}

	body {
		background: var(--bg);
		color: var(--ink);
		font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
		font-weight: 400;
		font-size: 16px;
		line-height: 1.55;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		text-rendering: optimizeLegibility;
	}

	.page {
		min-height: 100dvh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		padding: clamp(1.25rem, 4vw, 2.5rem);
		position: relative;
	}

	.stack {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: clamp(1rem, 3vh, 1.75rem);
		text-align: center;
		max-width: 36ch;
	}

	.brand {
		text-align: center;
	}

	.brand-mark {
		font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
		font-weight: 500;
		font-size: clamp(1.5rem, 3.2vw, 2.25rem);
		letter-spacing: 0.02em;
		color: var(--ink);
	}

	.tagline {
		margin: 0;
		font-style: italic;
		font-weight: 300;
		font-size: clamp(0.95rem, 1.4vw, 1.05rem);
		color: var(--ink);
		letter-spacing: 0.01em;
	}

	.links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.95rem;
		color: var(--muted);
	}

	.links a {
		color: var(--ink);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		padding-bottom: 1px;
		transition: border-color 160ms ease, color 160ms ease;
	}

	.links a:hover,
	.links a:focus-visible {
		border-bottom-color: var(--ink);
		outline: none;
	}

	.links span[aria-hidden="true"] {
		color: var(--muted);
		user-select: none;
	}

	.footer {
		position: absolute;
		bottom: clamp(1.25rem, 3vh, 2rem);
		left: 50%;
		transform: translateX(-50%);
		font-size: 0.75rem;
		color: var(--muted);
		letter-spacing: 0.02em;
		white-space: nowrap;
	}

	::selection {
		background: var(--ink);
		color: var(--bg);
	}

	@media (max-width: 480px) {
		.stack {
			max-width: 28ch;
		}

		.links {
			gap: 0.5rem;
			font-size: 0.9rem;
		}
	}
</style>
